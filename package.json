{
  "name": "cekat-sankey-chart",
  "version": "0.1.0",
  "description": "Lightweight Sankey chart for React dashboards",
  "author": "iwancinggg",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "keywords": [
    "sankey",
    "chart",
    "react",
    "visualization",
    "dashboard",
    "flow"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "prepublishOnly": "pnpm test:run && pnpm typecheck && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/d3-sankey": "^0.12",
    "@types/d3-shape": "^3",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6",
    "@typescript-eslint/parser": "^6",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "^8",
    "jsdom": "latest",
    "prettier": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5",
    "vite": "latest",
    "vite-plugin-dts": "latest",
    "vitest": "latest"
  }
}
